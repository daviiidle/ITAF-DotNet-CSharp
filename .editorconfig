root = true

[*.cs]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
insert_final_newline = true
dotnet_sort_system_directives_first = true
csharp_style_namespace_declarations = file_scoped

[*.{json,feature,yml,md}]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
insert_final_newline = true

